{
  "cleanUrls": true,
  "trailingSlash": false,

  "redirects": [
    {
      "source": "/:path*/",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/(.*)\\.html",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path((?!\\.html$).*)",
      "has": [
        {
          "type": "host",
          "value": "iscjava.online"
        }
      ],
      "destination": "https://www.iscjava.online/:path*",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/:path((?!\\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|pdf|json|xml|txt)$).*)",
      "destination": "/:path.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|pdf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}